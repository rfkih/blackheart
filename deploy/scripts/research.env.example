# Blackheart RESEARCH JVM env file (Windows)
#
# Path on prod host: C:\project\config\research.env
# Read by deploy/scripts/install-windows-services.sh and baked into the
# NSSM service config.
#
# Lock down ACLs:
#   icacls "C:\project\config\research.env" /inheritance:r /grant:r "Administrators:R" "SYSTEM:R"

# -- Spring profile (research JVM uses both prod + research profiles) --------
SPRING_PROFILES_ACTIVE=prod,research

# -- Logical JVM identity ----------------------------------------------------
BLACKHEART_JVM_NAME=research
APP_VERSION=1.0.0

# -- Network: research bound to localhost only (proxied by trading JVM) ------
RESEARCH_PORT=8081
RESEARCH_BIND_ADDRESS=127.0.0.1

# -- Database (V14 role separation: research uses a distinct, read-mostly user)
DB_URL=jdbc:postgresql://localhost:5432/trading_db
DB_USERNAME=blackheart_research
DB_PASSWORD=CHANGE_ME
DB_POOL_MAX=10
DB_POOL_MIN=2

# Flyway must be DISABLED on research JVM to prevent races with trading on
# schema_history. Trading JVM owns migrations.
FLYWAY_ENABLED=false

# -- Encryption + JWT (must MATCH trading.env values, otherwise inter-JVM
#    auth and shared encrypted columns break) -------------------------------
DB_ENCRYPTION_KEY=CHANGE_ME
JWT_SECRET=CHANGE_ME
JWT_EXPIRATION_MS=9000000

# -- Redis (shared with trading JVM) -----------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Research JVM disables most caching to keep each sweep deterministic.
RESEARCH_CACHE_TYPE=none

# -- External services -------------------------------------------------------
FASTAPI_URL=http://127.0.0.1:8000
NODEJS_URL=http://localhost:8088
RESEARCH_ORCH_BASE_URL=http://127.0.0.1:8082
RESEARCH_ORCH_TOKEN=CHANGE_ME

# -- Web / CORS / WebSocket (research is loopback-only; values rarely matter)
CORS_ALLOWED_ORIGINS=http://localhost:3000
WS_ALLOWED_ORIGINS=http://localhost:3000
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax

# -- Mail / Telegram: research JVM does not send alerts ----------------------
MAIL_ENABLED=false
ALERTS_TELEGRAM_ENABLED=false
ALERTS_EMAIL_ENABLED=false

# -- Watchdog disabled on research JVM ---------------------------------------
WATCHDOG_ENABLED=false

# -- Phase-1 dev auth kill-switch --------------------------------------------
BLACKHEART_DEV_AUTH_DISABLED=true
