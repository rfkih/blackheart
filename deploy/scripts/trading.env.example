# Blackheart TRADING JVM env file (Windows)
#
# Path on prod host: C:\project\config\trading.env
# Read by deploy/scripts/install-windows-services.sh and baked into the
# NSSM service config (registry-stored, not loaded at runtime).
#
# Lock down ACLs so only Administrators + the service account can read:
#   icacls "C:\project\config\trading.env" /inheritance:r /grant:r "Administrators:R" "SYSTEM:R"
#
# Any line starting with # or blank is ignored. Do NOT quote values.
# After editing, re-run install-windows-services.sh to apply.

# -- Spring profile (must be 'prod' for production) --------------------------
SPRING_PROFILES_ACTIVE=prod

# -- Logical JVM identity ----------------------------------------------------
BLACKHEART_JVM_NAME=trading
APP_VERSION=1.0.0

# -- Database ----------------------------------------------------------------
DB_URL=jdbc:postgresql://localhost:5432/trading_db
DB_USERNAME=blackheart_trading
DB_PASSWORD=CHANGE_ME
DB_POOL_MAX=30
DB_POOL_MIN=5

# Flyway baseline for a fresh DB bootstrapped from full_schema_v46.sql.
# After the first successful boot Flyway records V46 in flyway_schema_history;
# you may leave these set (idempotent) or remove them.
FLYWAY_ENABLED=true
SPRING_FLYWAY_BASELINE_ON_MIGRATE=true
SPRING_FLYWAY_BASELINE_VERSION=46

# -- Encryption key for Binance API credentials in 'accounts' table ----------
# REQUIRED. Generate with: openssl rand -base64 32
# WARNING: changing this after accounts have stored credentials makes them
# unreadable. Treat as a permanent secret.
DB_ENCRYPTION_KEY=CHANGE_ME

# -- JWT ---------------------------------------------------------------------
# REQUIRED. Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME
JWT_EXPIRATION_MS=9000000

# -- Redis -------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# -- External services -------------------------------------------------------
FASTAPI_URL=http://127.0.0.1:8000
NODEJS_URL=http://localhost:8088
RESEARCH_BASE_URL=http://127.0.0.1:8081
RESEARCH_ORCH_BASE_URL=http://127.0.0.1:8082
RESEARCH_ORCH_TOKEN=CHANGE_ME

# -- Live trading symbol -----------------------------------------------------
LIVE_SYMBOL=BTCUSDT

# -- Web / CORS / WebSocket --------------------------------------------------
CORS_ALLOWED_ORIGINS=https://app.example.com
WS_ALLOWED_ORIGINS=https://app.example.com
COOKIE_SECURE=true
COOKIE_SAMESITE=Lax

# -- Mail (set MAIL_ENABLED=false to disable outbound email) -----------------
MAIL_ENABLED=true
MAIL_HOST=live.smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME
MAIL_FROM=noreply@example.com
MAIL_FROM_NAME=Blackheart Ops

# -- Telegram alerts ---------------------------------------------------------
ALERTS_TELEGRAM_ENABLED=true
ALERTS_TELEGRAM_INFO_ENABLED=false
TELEGRAM_BOT_TOKEN=CHANGE_ME
TELEGRAM_CHAT_IDS=CHANGE_ME

# -- Email alerts ------------------------------------------------------------
ALERTS_EMAIL_ENABLED=false
ALERTS_EMAIL_TO=
ALERTS_EMAIL_FROM_NAME=Blackheart Ops

# -- Engine kill-switch ------------------------------------------------------
ENGINE_KILL_SWITCH_ERROR_THRESHOLD=5
ENGINE_KILL_SWITCH_ERROR_WINDOW_MINUTES=10
ENGINE_SPEC_HOT_RELOAD_ENABLED=false
BLACKHEART_ENGINE_PARAMETRIC_ENABLED=true

# -- Watchdog ----------------------------------------------------------------
WATCHDOG_ENABLED=true
WATCHDOG_INTERVAL_MS=300000
WATCHDOG_INGEST_INTERVALS=5m
WATCHDOG_INGEST_STALLED_MINUTES=15
WATCHDOG_TRADE_STUCK_HOURS=24

# -- Phase-1 dev auth kill-switch (must be true in prod) ---------------------
BLACKHEART_DEV_AUTH_DISABLED=true
