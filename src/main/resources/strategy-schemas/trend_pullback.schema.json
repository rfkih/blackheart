{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://blackheart.local/schemas/trend_pullback.schema.json",
  "title": "trend_pullback param overrides",
  "description": "Validates the param_overrides map for any spec-driven strategy with archetype=trend_pullback. Mirrors EPB-style pullback entries on EMA stack.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "pullbackTouchAtr":     {"type": "number", "exclusiveMinimum": 0, "maximum": 5},
    "adxRisingMin":         {"type": "number", "minimum": 0, "maximum": 100},
    "adxEntryMin":          {"type": "number", "minimum": 0, "maximum": 100},
    "stopAtrBuffer":        {"type": "number", "exclusiveMinimum": 0, "maximum": 5},
    "tp1R":                 {"type": "number", "exclusiveMinimum": 0, "maximum": 20},
    "breakEvenR":           {"type": "number", "minimum": 0, "maximum": 5},
    "maxEntryRiskPct":      {"type": "number", "exclusiveMinimum": 0, "maximum": 0.5},
    "maxBarsHeld":          {"type": "integer", "minimum": 1, "maximum": 1000},
    "intervalMinutes":      {"type": "integer", "minimum": 1, "maximum": 1440},
    "useRiskBasedSizing":   {"type": "boolean"},
    "riskPct":              {"type": "number", "exclusiveMinimum": 0, "maximum": 0.1}
  }
}
